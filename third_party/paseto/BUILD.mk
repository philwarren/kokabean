PKGS += THIRD_PARTY_PASETO

THIRD_PARTY_PASETO_SRCS = $(THIRD_PARTY_PASETO_A_SRCS)
THIRD_PARTY_PASETO_HDRS = $(THIRD_PARTY_PASETO_A_HDRS)

THIRD_PARTY_PASETO_ARTIFACTS += THIRD_PARTY_PASETO_A
THIRD_PARTY_PASETO = $(THIRD_PARTY_PASETO_A_DEPS) $(THIRD_PARTY_PASETO_A)
THIRD_PARTY_PASETO_A = o/$(MODE)/third_party/paseto/paseto.a
THIRD_PARTY_PASETO_A_FILES := $(wildcard third_party/paseto/*)
THIRD_PARTY_PASETO_A_HDRS = $(filter %.h,$(THIRD_PARTY_PASETO_A_FILES))
THIRD_PARTY_PASETO_A_SRCS_C = $(filter %.c,$(THIRD_PARTY_PASETO_A_FILES))
THIRD_PARTY_PASETO_A_SRCS_S = $(filter %.S,$(THIRD_PARTY_PASETO_A_FILES))

THIRD_PARTY_PASETO_A_SRCS =				\
	$(THIRD_PARTY_PASETO_A_SRCS_S)			\
	$(THIRD_PARTY_PASETO_A_SRCS_C)

THIRD_PARTY_PASETO_A_OBJS =				\
	$(THIRD_PARTY_PASETO_A_SRCS_C:%.c=o/$(MODE)/%.o)	\
	$(THIRD_PARTY_PASETO_A_SRCS_S:%.S=o/$(MODE)/%.o)

THIRD_PARTY_PASETO_A_DIRECTDEPS =				\
	LIBC_CALLS						\
	LIBC_LOG						\
	LIBC_MEM						\
	LIBC_STDIO						\
	LIBC_STR						\
	LIBC_INTRIN						\
	NET_HTTP						\
	THIRD_PARTY_ARGON2					\
	THIRD_PARTY_MBEDTLS

THIRD_PARTY_PASETO_A_DEPS :=				\
	$(call uniq,$(foreach x,$(THIRD_PARTY_PASETO_A_DIRECTDEPS),$($(x))))

THIRD_PARTY_PASETO_A_CHECKS =				\
	$(THIRD_PARTY_PASETO_A).pkg			\
	$(THIRD_PARTY_PASETO_A_HDRS:%=o/$(MODE)/%.ok)

$(THIRD_PARTY_PASETO_A):					\
		third_party/paseto/			\
		$(THIRD_PARTY_PASETO_A).pkg		\
		$(THIRD_PARTY_PASETO_A_OBJS)

$(THIRD_PARTY_PASETO_A).pkg:				\
		$(THIRD_PARTY_PASETO_A_OBJS)		\
		$(foreach x,$(THIRD_PARTY_PASETO_A_DIRECTDEPS),$($(x)_A).pkg)

THIRD_PARTY_PASETO_LIBS = $(foreach x,$(THIRD_PARTY_PASETO_ARTIFACTS),$($(x)))
THIRD_PARTY_PASETO_SRCS = $(foreach x,$(THIRD_PARTY_PASETO_ARTIFACTS),$($(x)_SRCS))
THIRD_PARTY_PASETO_CHECKS = $(foreach x,$(THIRD_PARTY_PASETO_ARTIFACTS),$($(x)_CHECKS))
THIRD_PARTY_PASETO_OBJS = $(foreach x,$(THIRD_PARTY_PASETO_ARTIFACTS),$($(x)_OBJS))
$(THIRD_PARTY_PASETO_OBJS): third_party/paseto/BUILD.mk

.PHONY: o/$(MODE)/third_party/paseto
o/$(MODE)/third_party/paseto:						\
	$(THIRD_PARTY_PASETO_CHECKS)
